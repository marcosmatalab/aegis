# Aegis F3 golden anchor set — hand-made eval cases (one JSON EvalCase per line).
# Interleaves passing and failing cases so every L1/L2/L3 metric has positive AND
# negative coverage, plus several cases where one level PASSES while another FAILS
# (to demonstrate the levels are independent). `expected` is the per-level oracle;
# the golden test asserts the real scorers reproduce it.
#
# --- happy paths (all three levels pass) ---
{"id": "weather-happy", "user_goal": "Get the weather in Madrid", "input_messages": [{"role": "user", "content": "What's the weather in Madrid?"}], "expected_trajectory": [{"name": "get_weather", "arguments": {"city": "Madrid"}}], "reference_answer": "Madrid sunny 30 degrees", "context": ["Madrid weather sunny 30 degrees"], "success_criteria": {"must_include": ["Madrid", "30"], "must_not_include": ["error"]}, "actual": {"final_output": "Madrid sunny 30 degrees", "tool_calls": [{"name": "get_weather", "arguments": {"city": "Madrid"}}]}, "expected": {"l1_goal_met": true, "l2_faithful": true, "l3_trajectory_match": true}, "tags": ["happy-path"]}
{"id": "search-happy", "user_goal": "Find the capital of France", "input_messages": [{"role": "user", "content": "Capital of France?"}], "expected_trajectory": [{"name": "web_search", "arguments": {"q": "capital france"}}], "reference_answer": "Paris capital France", "context": ["France capital Paris"], "success_criteria": {"must_include": ["Paris"]}, "actual": {"final_output": "Paris capital France", "tool_calls": [{"name": "web_search", "arguments": {"q": "capital france"}}]}, "expected": {"l1_goal_met": true, "l2_faithful": true, "l3_trajectory_match": true}, "tags": ["happy-path"]}
{"id": "notool-answer-happy", "user_goal": "Greet politely", "input_messages": [{"role": "user", "content": "say hi"}], "expected_trajectory": [], "reference_answer": "hello friend welcome", "context": ["hello friend welcome aboard"], "success_criteria": {"must_include": ["hello"]}, "actual": {"final_output": "hello friend welcome", "tool_calls": []}, "expected": {"l1_goal_met": true, "l2_faithful": true, "l3_trajectory_match": true}, "tags": ["happy-path", "no-tools"]}
{"id": "multi-tool-pipeline-ok", "user_goal": "Search then summarize", "input_messages": [{"role": "user", "content": "Summarize the latest news"}], "expected_trajectory": [{"name": "web_search", "arguments": {"q": "news"}}, {"name": "summarize", "arguments": {}}], "reference_answer": "summary news today", "context": ["news today summary brief"], "success_criteria": {"must_include": ["summary"]}, "actual": {"final_output": "summary news today", "tool_calls": [{"name": "web_search", "arguments": {"q": "news"}}, {"name": "summarize", "arguments": {}}]}, "expected": {"l1_goal_met": true, "l2_faithful": true, "l3_trajectory_match": true}, "tags": ["happy-path", "pipeline"]}

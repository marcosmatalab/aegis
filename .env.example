# Aegis — example environment file. Copy to `.env` and fill in real values.
# Never commit `.env` (it is git-ignored).

# --- LLM providers (multi-provider, OpenAI-compatible gateway) ---
# Keys are optional and unused in F1 (the deterministic mock needs none). The
# planned primary real provider is Anthropic (Claude); OpenAI and Gemini are
# additional options. Provider SDKs are NOT wired yet.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Upstream provider the gateway uses. F1 ships ONLY "mock" (deterministic,
# keyless). Selecting "anthropic"/"openai"/"google" is reserved for a later
# phase and currently returns a clean provider_not_configured error.
AEGIS_DEFAULT_PROVIDER=mock

# Default upstream model the gateway proxies to (provider/model).
AEGIS_DEFAULT_MODEL=anthropic/claude-opus-4-6

# --- Gateway server ---
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8080
AEGIS_LOG_LEVEL=info

# --- F2 guardrails (master OFF by default = byte-identical F1 passthrough) ---
AEGIS_GUARDRAILS_ENABLED=false
# Input checks (gated behind the master switch)
AEGIS_GR_INJECTION_ENABLED=true
AEGIS_GR_PII_REDACT_INPUT=true
AEGIS_GR_POLICY_ENABLED=true
# Output checks
AEGIS_GR_OUTPUT_PII_ENABLED=true
AEGIS_GR_OUTPUT_PII_ACTION=block   # block | redact
AEGIS_GR_TOXICITY_ENABLED=true
AEGIS_GR_TOXICITY_THRESHOLD=0.5
# PII engine: "regex" (default, no deps) or "presidio" (needs the [guardrails] extra)
AEGIS_GR_PII_ENGINE=regex
# Policy rules as JSON arrays of case-insensitive regex, e.g. '["\\bsecret\\b"]'
AEGIS_GR_POLICY_DENY=[]
AEGIS_GR_POLICY_ALLOW=[]

# --- Persistence (runs, verdicts, cases, red-team results) ---
DATABASE_URL=postgresql+psycopg://aegis:aegis@localhost:5432/aegis

# --- Observability (OpenTelemetry GenAI semconv -> Langfuse) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Evals / LLM-as-judge ---
AEGIS_JUDGE_MODEL=anthropic/claude-opus-4-6
AEGIS_EVAL_FAIL_UNDER=0.80
# L2 judge backend: "mock" (deterministic, offline default) | "geval" | "ensemble"
AEGIS_JUDGE_BACKEND=mock

# --- F4 Agent-as-a-Judge (trajectory) + CLEAR ---
# Trajectory judge backend: "mock" (deterministic heuristic, offline default) |
# "agent" (real reasoning LLM — a clear stub until a later phase).
AEGIS_AGENT_JUDGE_BACKEND=mock
# Optional CLEAR budgets/SLOs. When set, the Cost/Latency dimensions get a
# normalized 0..1 score; otherwise only the raw (synthetic) value is reported.
# Real cost/latency telemetry arrives with live providers + OpenTelemetry (F1.x).
AEGIS_CLEAR_COST_BUDGET_USD=
AEGIS_CLEAR_LATENCY_BUDGET_MS=

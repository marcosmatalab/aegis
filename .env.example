# Aegis — example environment file. Copy to `.env` and fill in real values.
# Never commit `.env` (it is git-ignored).

# --- LLM providers (multi-provider, OpenAI-compatible gateway) ---
# Keys are optional: the deterministic mock provider needs none. Anthropic
# (Claude) is the first REAL provider wired; set ANTHROPIC_API_KEY and install
# the SDK with `pip install -e ".[anthropic]"`. OpenAI/Gemini are not wired yet.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Upstream provider the gateway uses. "mock" is the deterministic, keyless
# default. Set "anthropic" to forward to real Claude (needs the key + the
# [anthropic] extra); "openai"/"google" still return provider_not_configured.
AEGIS_DEFAULT_PROVIDER=mock

# Default upstream model the gateway proxies to (provider/model). For Anthropic
# the leading "anthropic/" prefix is stripped before the call.
AEGIS_DEFAULT_MODEL=anthropic/claude-opus-4-8

# --- Real Anthropic provider adapter (only used when DEFAULT_PROVIDER=anthropic) ---
# Anthropic requires max_tokens (OpenAI makes it optional); this is the default
# when a request omits max_tokens/max_completion_tokens.
AEGIS_ANTHROPIC_MAX_TOKENS=4096
# Optional base URL override (proxies/testing). Leave blank for the real API.
AEGIS_ANTHROPIC_BASE_URL=
AEGIS_ANTHROPIC_TIMEOUT_S=60.0

# --- Gateway server ---
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8080
AEGIS_LOG_LEVEL=info

# --- F2 guardrails (master OFF by default = byte-identical F1 passthrough) ---
AEGIS_GUARDRAILS_ENABLED=false
# Input checks (gated behind the master switch)
AEGIS_GR_INJECTION_ENABLED=true
AEGIS_GR_PII_REDACT_INPUT=true
AEGIS_GR_POLICY_ENABLED=true
# Output checks
AEGIS_GR_OUTPUT_PII_ENABLED=true
AEGIS_GR_OUTPUT_PII_ACTION=block   # block | redact
AEGIS_GR_TOXICITY_ENABLED=true
AEGIS_GR_TOXICITY_THRESHOLD=0.5
# PII engine: "regex" (default, no deps) or "presidio" (needs the [guardrails] extra)
AEGIS_GR_PII_ENGINE=regex
# Policy rules as JSON arrays of case-insensitive regex, e.g. '["\\bsecret\\b"]'
AEGIS_GR_POLICY_DENY=[]
AEGIS_GR_POLICY_ALLOW=[]

# --- Persistence (runs, verdicts, cases, red-team results) ---
DATABASE_URL=postgresql+psycopg://aegis:aegis@localhost:5432/aegis

# --- Observability (OpenTelemetry GenAI semconv -> Langfuse) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Evals / LLM-as-judge ---
AEGIS_JUDGE_MODEL=anthropic/claude-opus-4-6
AEGIS_EVAL_FAIL_UNDER=0.80
